# ─────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────
BACKEND_URL=http://localhost:8080

# ─────────────────────────────────────────
# DATABASE — Local (Docker)
# ─────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=caaampaign
POSTGRES_PASSWORD=caaampaign_secret
POSTGRES_DB=caaampaign_db

# ─────────────────────────────────────────
# DATABASE — Railway / Production
# Replace the block above with these when deploying to Railway
# ─────────────────────────────────────────
# DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<db>
# DATABASE_PUBLIC_URL=postgresql://<user>:<password>@<host>:<port>/<db>
# POSTGRES_HOST=<railway-proxy-host>
# POSTGRES_PORT=<railway-proxy-port>
# POSTGRES_USER=<railway-user>
# POSTGRES_PASSWORD=<railway-password>
# POSTGRES_DB=<railway-db>
# PGHOST=<railway-internal-host>
# PGPORT=5432
# PGUSER=<railway-user>
# PGPASSWORD=<railway-password>
# PGDATABASE=<railway-db>

# ─────────────────────────────────────────
# CLOUDINARY — Image CDN
# https://cloudinary.com/console
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────
# GMAIL — Transactional Email (OAuth2)
# https://console.cloud.google.com → OAuth2 credentials
# ─────────────────────────────────────────
GMAIL_USER=your@gmail.com
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token
